
# ── Claves de API Groq — un LLM por agente (rate limits distribuidos) ──────────
# Cada agente usa su propia clave para no compartir el límite de 6000 TPM.
# Obtén claves gratuitas en: https://console.groq.com/keys

GROQ_KEY_SUPERVISOR=gsk_...
GROQ_KEY_REDACTOR=gsk_...
GROQ_KEY_AUDITOR=gsk_...
GROQ_KEY_METODOLOGICO=gsk_...
GROQ_KEY_CONSENSO=gsk_...
GROQ_KEY_DISENSO=gsk_...

# Clave de respaldo — se usa si alguna clave específica no está configurada
GROQ_API_KEY=gsk_...

# Claves para rotación en el panel de subagentes del Auditor (CAMBIO 6)
# Si se dejan vacías, todos los subagentes usan GROQ_KEY_AUDITOR
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=


# ── Storage — dejar vacío para usar almacenamiento local ─────────────────────
# Si GCS_BUCKET_NAME está definido, los JSONs de run se suben automáticamente
GCS_BUCKET_NAME=

# Fuente de rúbricas: local | gcs | gdrive
CONTEXT_SOURCE=local

# Google Drive — JSON mapeando key → file_id de Drive
# Ejemplo: {"upao_ingenieria_de_sistemas_tesis": "1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms"}
GDRIVE_RUBRIC_MAP={}


# ── Parámetros del flujo ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_ITERATIONS=3
MAX_DEBATE_ROUNDS=2


# ── LangSmith (opcional — para tracing y debugging) ───────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls_...
# LANGCHAIN_PROJECT=mentoria-multiagente
