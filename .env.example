
# ══════════════════════════════════════════════════════════════════════════════
# CLAVES API GROQ — Sistema de rotación para subagentes paralelos
# ══════════════════════════════════════════════════════════════════════════════
#
# CÓMO FUNCIONA EL SISTEMA DE CLAVES:
#
#  1. Cada nodo principal tiene su propia clave:
#       GROQ_KEY_SUPERVISOR, GROQ_KEY_AUDITOR, etc.
#     Si no se configura, todos caen a GROQ_API_KEY (clave de respaldo).
#
#  2. Los PANELES DE SUBAGENTES (Auditor×3, Metodólogo×2, Redactor×2, Disenso×2)
#     usan un pool de rotación formado por GROQ_API_KEY_1, _2, _3…
#     Subagente 0 → GROQ_API_KEY_1
#     Subagente 1 → GROQ_API_KEY_2
#     Subagente 2 → GROQ_API_KEY_3
#
#  IMPORTANTE: GROQ_API_KEY_1, _2, _3 deben ser claves VÁLIDAS.
#  Si están vacías o expiradas, el subagente correspondiente falla con 401.
#  Obtén claves gratuitas en: https://console.groq.com/keys
#  (puedes crear múltiples claves en la misma cuenta)
#
# ──────────────────────────────────────────────────────────────────────────────

# Clave de respaldo — usada cuando no hay clave específica por nodo
GROQ_API_KEY=gsk_...

# Claves por nodo principal (opcional pero recomendado para distribuir TPM)
GROQ_KEY_SUPERVISOR=gsk_...
GROQ_KEY_REDACTOR=gsk_...
GROQ_KEY_AUDITOR=gsk_...
GROQ_KEY_METODOLOGICO=gsk_...
GROQ_KEY_CONSENSO=gsk_...
GROQ_KEY_DISENSO=gsk_...

# Claves para el pool de rotación de subagentes (OBLIGATORIO para evitar 401)
# Subagente 0 → _1,  Subagente 1 → _2,  Subagente 2 → _3
# Si solo tienes una clave adicional, pon la misma en _1, _2 y _3
GROQ_API_KEY_1=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...


# ── Storage — dejar vacío para usar almacenamiento local ─────────────────────
# Si GCS_BUCKET_NAME está definido, los JSONs de run se suben automáticamente
GCS_BUCKET_NAME=

# Fuente de rúbricas: local | gcs | gdrive
CONTEXT_SOURCE=local

# Google Drive — JSON mapeando key → file_id de Drive
# Ejemplo: {"upao_ingenieria_de_sistemas_tesis": "1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms"}
GDRIVE_RUBRIC_MAP={}


# ── Parámetros del flujo ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_ITERATIONS=3
MAX_DEBATE_ROUNDS=2


# ── LangSmith (opcional — para tracing y debugging) ───────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls_...
# LANGCHAIN_PROJECT=mentoria-multiagente
